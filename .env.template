# 0DTE Alert OpenClaw Configuration Template
# Copy this file to .env and fill in your actual values

# Required: Anthropic API Key for Claude AI evaluation
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Telegram Bot Integration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Optional: Market Data API (if required by your data source)
MARKET_DATA_API_KEY=your-market-data-api-key

# Application Settings
LOG_LEVEL=INFO
ALERT_COOLDOWN_MINUTES=30
PRICE_TOLERANCE_POINTS=18